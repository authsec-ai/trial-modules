# Aegis Voice Agent --- Environment Variables
# Copy this file to .env and fill in your values.
#
# NOTE: The recommended way to set CLIENT_ID is via `authsec init`,
# which creates .authsec.json. The env vars below are optional overrides.

# Required: OpenAI API key (for Whisper STT, TTS, and GPT-4o-mini)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# AuthSec CIBA --- these override .authsec.json if set
# CLIENT_ID=your-client-id-here
# CIBA_BASE_URL=https://prod.api.authsec.ai

# Optional: Amadeus API for real flight data (mock data used if not set)
# Sign up free at https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
